# ==========================================================
# GCLOUD IGNORE - PREVENT UPLOADING LOCAL BUILD ARTIFACTS
# ==========================================================

# Ignore git metadata
.git
.gitignore
.gcloudignore

# Ignore heavy local dependencies and build outputs
node_modules/
.next/
out/
build/

# Ignore local environment credentials and environment files
.env.local
.env.*.local
.env

# Ignore OS logs and caches
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Ignore temporary test files
test-*.js
test-imagen.js
test-locations.js
test-gemini.js
